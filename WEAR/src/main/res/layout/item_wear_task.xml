<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:tools="http://schemas.android.com/tools" android:layout_width="match_parent" android:layout_height="wrap_content" android:background="@drawable/bg_wear_task_item" android:layout_marginHorizontal="4dp" android:layout_marginVertical="3dp" android:minHeight="44dp">
    <!--  Priority color bar (left edge)  -->
    <View android:id="@+id/viewPriorityBar" android:layout_width="3dp" android:layout_height="0dp" android:background="#6C63FF" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent"/>
    <!--  Category emoji  -->
    <TextView android:id="@+id/txtWearCategory" android:layout_width="20dp" android:layout_height="wrap_content" android:layout_marginStart="8dp" android:gravity="center" android:textSize="13sp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toEndOf="@id/viewPriorityBar" app:layout_constraintTop_toTopOf="parent" tools:text="📌"/>
    <!--  Task title  -->
    <TextView android:id="@+id/txtWearTaskTitle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="6dp" android:layout_marginEnd="4dp" android:textColor="#FFFFFF" android:textSize="12sp" android:maxLines="2" android:ellipsize="end" android:paddingVertical="8dp" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toStartOf="@id/btnWearCheck" app:layout_constraintStart_toEndOf="@id/txtWearCategory" app:layout_constraintTop_toTopOf="parent" tools:text="Complete Android assignment"/>
    <!--  Check button  -->
    <ImageButton android:id="@+id/btnWearCheck" android:layout_width="28dp" android:layout_height="28dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_wear_check_outline" android:padding="2dp" app:tint="#69F0AE" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toStartOf="@id/btnWearDelete" app:layout_constraintTop_toTopOf="parent" android:contentDescription="Mark done"/>
    <!--  Delete button  -->
    <ImageButton android:id="@+id/btnWearDelete" android:layout_width="28dp" android:layout_height="28dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@android:drawable/ic_menu_delete" android:padding="4dp" app:tint="#FF5252" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" android:contentDescription="Delete task" android:layout_marginEnd="4dp"/>
</androidx.constraintlayout.widget.ConstraintLayout>