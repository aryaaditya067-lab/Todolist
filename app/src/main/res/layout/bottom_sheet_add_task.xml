<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bottomSheetRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:clipToPadding="false"
    android:paddingTop="12dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="8dp"
        android:paddingBottom="32dp">

        <!-- Drag Handle -->
        <View
            android:id="@+id/dragHandle"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="?android:attr/textColorSecondary"
            android:alpha="0.2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Title Section -->
        <EditText
            android:id="@+id/editTaskTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@null"
            android:hint="What's your next move?"
            android:inputType="textCapSentences"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:fontFamily="sans-serif-medium"
            android:textSize="26sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/dragHandle" />

        <!-- Category Suggestion / Tips -->
        <TextView
            android:id="@+id/txtCategorySuggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/accent_orange"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editTaskTitle"
            tools:text="Suggesting: Health"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/txtPrioritySuggestion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/accent_orange"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/txtCategorySuggestion"
            tools:text="Priority: HIGH ⚡"
            tools:visibility="visible" />

        <!-- Article Preview Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/layoutArticlePreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/accent_orange"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/txtCategorySuggestion">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="12dp"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/txtArticleIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="20sp"
                    tools:text="🏋️" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="10dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/txtArticleTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        tools:text="Gym Tips" />

                    <TextView
                        android:id="@+id/txtArticleSummary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp"
                        android:maxLines="1"
                        android:ellipsize="end"
                        tools:text="Read how to stay consistent at gym." />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tips →"
                    android:textColor="@color/accent_orange"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- AI Suggestion Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAiSuggestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:visibility="gone"
            app:cardBackgroundColor="@color/card_bg"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/accent_orange"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/layoutArticlePreview">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="AI Suggestion"
                    android:textColor="@color/accent_orange"
                    android:textSize="10sp"
                    android:textStyle="bold" />

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <ProgressBar
                        android:id="@+id/progressAiSuggestion"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:visibility="gone" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/txtAiSuggestion"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:textColor="@color/text_primary"
                            android:textSize="13sp"
                            tools:text="Try focusing on the core logic first." />

                        <TextView
                            android:id="@+id/btnAddSuggestion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ADD +"
                            android:textColor="@color/accent_orange"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:padding="8dp"
                            android:background="?attr/selectableItemBackground"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </FrameLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <EditText
            android:id="@+id/editTaskDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@null"
            android:hint="Add more detail..."
            android:inputType="textMultiLine"
            android:textColor="@color/text_secondary"
            android:textColorHint="@color/text_secondary"
            android:textSize="17sp"
            app:layout_constraintTop_toBottomOf="@id/cardAiSuggestion" />

        <!-- Date Picker Button -->
        <LinearLayout
            android:id="@+id/layoutDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_glass_card"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/editTaskDesc">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="@color/accent_orange" />

            <TextView
                android:id="@+id/txtSelectedDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Today"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- Focus Timer Section -->
        <LinearLayout
            android:id="@+id/layoutTimerSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/layoutDate">

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchTimer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Deep Focus Timer"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/text_primary"
                app:thumbTint="@color/accent_orange"
                app:trackTint="@color/glass_white_10" />

            <LinearLayout
                android:id="@+id/layoutDurationPicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Duration (minutes)"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp" />

                <EditText
                    android:id="@+id/editCustomMinutes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_glass_card"
                    android:hint="Set focus time (e.g. 25)"
                    android:inputType="number"
                    android:padding="16dp"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="16sp" />

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchAutoComplete"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Auto-complete on finish"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    app:thumbTint="@color/accent_orange"
                    app:trackTint="@color/glass_white_10" />
            </LinearLayout>
        </LinearLayout>

        <!-- Repeat Section -->
        <com.google.android.material.materialswitch.MaterialSwitch
            android:id="@+id/switchRepeat"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Repeat Daily"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"
            app:thumbTint="@color/accent_orange"
            app:trackTint="@color/glass_white_10"
            app:layout_constraintTop_toBottomOf="@id/layoutTimerSection" />

        <LinearLayout
            android:id="@+id/layoutRepeatOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            app:layout_constraintTop_toBottomOf="@id/switchRepeat">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupRepeat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                app:singleSelection="true">
                <com.google.android.material.chip.Chip android:id="@+id/chipDaily" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Daily" android:textColor="@color/text_primary" />
                <com.google.android.material.chip.Chip android:id="@+id/chipWeekdays" style="@style/Widget.Material3.Chip.Filter" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Weekdays" android:textColor="@color/text_primary" />
            </com.google.android.material.chip.ChipGroup>
        </LinearLayout>

        <!-- Notes Section -->
        <TextView
            android:id="@+id/btnToggleNotes"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Add Notes +"
            android:textColor="@color/accent_orange"
            android:textSize="14sp"
            android:fontFamily="sans-serif-bold"
            android:paddingVertical="8dp"
            app:layout_constraintTop_toBottomOf="@id/layoutRepeatOptions"
            app:layout_constraintStart_toStartOf="parent" />

        <EditText
            android:id="@+id/editNotes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_task"
            android:backgroundTint="@color/card_bg"
            android:hint="Any extra thoughts?"
            android:padding="16dp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:textSize="14sp"
            android:visibility="gone"
            android:gravity="top"
            android:minLines="3"
            app:layout_constraintTop_toBottomOf="@id/btnToggleNotes" />

        <!-- Action Button -->
        <Button
            android:id="@+id/btnCreateTask"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="32dp"
            android:text="Set Intent"
            android:textSize="18sp"
            android:textStyle="bold"
            android:backgroundTint="@color/accent_orange"
            android:textColor="@color/white"
            app:cornerRadius="16dp"
            app:elevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/editNotes"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
