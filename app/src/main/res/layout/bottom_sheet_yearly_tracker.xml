<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main"
    android:padding="24dp">

    <LinearLayout
        android:id="@+id/yearlyContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtYearTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Typography.Header"
            android:textSize="24sp"
            android:text="2025 Focus"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="8dp"/>

        <TextView
            android:id="@+id/txtYearSummary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/Typography.Meta"
            android:text="0 days completed this year"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="24dp"/>

        <!-- Months will be added dynamically -->
        <LinearLayout
            android:id="@+id/layoutMonths"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
