<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/settingsRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_main_gradient"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_revert"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            style="@style/Typography.Title"
            android:textSize="20sp"
            android:text="Settings"
            android:textColor="@color/text_primary"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@id/btnBack"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Account Section -->
            <TextView
                style="@style/Typography.Header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"
                android:text="Account"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <TextView
                    android:id="@+id/txtUserEmail"
                    style="@style/Typography.Body"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Not logged in"
                    android:textColor="@color/text_primary"
                    app:layout_constraintEnd_toStartOf="@id/btnLogout"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Button
                    android:id="@+id/btnLogout"
                    style="@style/Widget.Material3.Button.TextButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Logout"
                    android:textColor="@color/accent_primary"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Appearance Section -->
            <TextView
                style="@style/Typography.Header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"
                android:text="Appearance"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <TextView
                    android:id="@+id/lblTheme"
                    style="@style/Typography.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Theme Mode"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Spinner
                    android:id="@+id/spinnerTheme"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/lblTheme"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/lblTheme" />

                <View
                    android:id="@+id/divider5"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/divider_color"
                    app:layout_constraintTop_toBottomOf="@id/lblTheme" />

                <TextView
                    android:id="@+id/lblFontSize"
                    style="@style/Typography.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Font Size"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider5" />

                <Spinner
                    android:id="@+id/spinnerFontSize"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/lblFontSize"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/lblFontSize" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- General Section -->
            <TextView
                style="@style/Typography.Header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"
                android:text="General"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <TextView
                    android:id="@+id/lblDefaultDuration"
                    style="@style/Typography.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Default Task Duration"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <Spinner
                    android:id="@+id/spinnerDuration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/lblDefaultDuration"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/lblDefaultDuration" />

                <View
                    android:id="@+id/divider1"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/divider_color"
                    app:layout_constraintTop_toBottomOf="@id/lblDefaultDuration" />

                <TextView
                    android:id="@+id/lblAskBeforeStart"
                    style="@style/Typography.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ask Before Starting Timer"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider1" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAskStart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/lblAskBeforeStart"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/lblAskBeforeStart" />

                <View
                    android:id="@+id/dividerSync"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/divider_color"
                    app:layout_constraintTop_toBottomOf="@id/switchAskStart" />

                <TextView
                    android:id="@+id/lblCalendarSync"
                    style="@style/Typography.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sync with Phone Calendar"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/dividerSync" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchCalendarSync"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/lblCalendarSync"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/lblCalendarSync" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Timer Section -->
            <TextView
                style="@style/Typography.Header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"
                android:text="Timer"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <TextView
                    android:id="@+id/lblTimerMode"
                    style="@style/Typography.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Timer Mode"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <RadioGroup
                    android:id="@+id/rgTimerMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent">
                    <RadioButton android:id="@+id/rbCountdown" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Countdown" android:textSize="12sp" android:textColor="@color/text_primary"/>
                    <RadioButton android:id="@+id/rbStopwatch" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Stopwatch" android:textSize="12sp" android:textColor="@color/text_primary"/>
                </RadioGroup>

                <View
                    android:id="@+id/divider2"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/divider_color"
                    app:layout_constraintTop_toBottomOf="@id/rgTimerMode" />

                <TextView
                    android:id="@+id/lblOneTimer"
                    style="@style/Typography.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Only One Running Timer"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider2" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchOneTimer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/lblOneTimer"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/lblOneTimer" />

                <View
                    android:id="@+id/divider3"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/divider_color"
                    app:layout_constraintTop_toBottomOf="@id/lblOneTimer" />

                <TextView
                    android:id="@+id/lblAutoComplete"
                    style="@style/Typography.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Auto-Complete on Timer End"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider3" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAutoComplete"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/lblAutoComplete"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/lblAutoComplete" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Notifications Section -->
            <TextView
                style="@style/Typography.Header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"
                android:text="Notifications"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <TextView
                    android:id="@+id/lblReminderNotif"
                    style="@style/Typography.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Task Reminders"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchReminderNotif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/lblReminderNotif"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/lblReminderNotif" />

                <View
                    android:id="@+id/divider4"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginVertical="16dp"
                    android:background="@color/divider_color"
                    app:layout_constraintTop_toBottomOf="@id/lblReminderNotif" />

                <TextView
                    android:id="@+id/lblTimerFinishedNotif"
                    style="@style/Typography.Body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Timer Finished Notification"
                    android:textColor="@color/text_primary"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/divider4" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchTimerNotif"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintBottom_toBottomOf="@id/lblTimerFinishedNotif"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/lblTimerFinishedNotif" />

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Data Section -->
            <TextView
                style="@style/Typography.Header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:layout_marginStart="4dp"
                android:text="Data &amp; Progress"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="48dp"
                android:background="@drawable/bg_glass_card"
                android:padding="16dp">

                <Button
                    android:id="@+id/btnResetToday"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/glass_white_10"
                    android:text="Reset Today's Progress"
                    android:textColor="@color/text_primary"
                    app:layout_constraintTop_toTopOf="parent" />

                <Button
                    android:id="@+id/btnResetStreak"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:backgroundTint="@color/glass_white_10"
                    android:text="Reset Monthly Streak"
                    android:textColor="@color/text_primary"
                    app:layout_constraintTop_toBottomOf="@id/btnResetToday" />

            </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
